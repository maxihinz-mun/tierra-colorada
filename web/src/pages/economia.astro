---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ArticuloCard from "../components/ArticuloCard.astro";

const notas = (await getCollection("articulos", ({ data }) => data.seccion === "economia"))
  .sort((a, b) => b.data.fecha.valueOf() - a.data.fecha.valueOf());
---

<BaseLayout titulo="Economía — Tierra Colorada" descripcion="Cobertura económica de Corrientes: yerba, arroz, ganadería, foresto, comercio y finanzas públicas.">
  <div class="container">
    <header class="section-title">
      <h1>Economía</h1>
      <p>Producción regional, finanzas provinciales, empleo y comercio.</p>
    </header>
    {notas.length === 0 ? (
      <p style="color:var(--niebla);">Aún no hay notas publicadas en esta sección.</p>
    ) : (
      <div class="grilla">
        {notas.map((n) => (
          <ArticuloCard
            titulo={n.data.titulo}
            bajada={n.data.bajada}
            seccion={n.data.seccion}
            autor={n.data.autor}
            fecha={n.data.fecha}
            slug={n.slug}
          />
        ))}
      </div>
    )}
  </div>
</BaseLayout>
