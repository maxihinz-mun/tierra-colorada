---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const notas = await getCollection("articulos");
  return notas.map((n) => ({
    params: { slug: n.slug },
    props: { nota: n },
  }));
}

interface Props { nota: CollectionEntry<"articulos">; }
const { nota } = Astro.props;
const { Content } = await nota.render();

const seccionLabel = { politica: "Política", economia: "Economía", sociedad: "Sociedad" }[nota.data.seccion];
const generoLabel = { noticia: null, opinion: "Opinión", analisis: "Análisis" }[nota.data.genero];
const fechaFmt = new Intl.DateTimeFormat("es-AR", {
  day: "numeric", month: "long", year: "numeric",
}).format(nota.data.fecha);
---

<BaseLayout titulo={`${nota.data.titulo} — Tierra Colorada`} descripcion={nota.data.bajada}>
  <article class="container articulo">
    <p class="kicker">
      <a href={`/${nota.data.seccion}`} class="seccion">{seccionLabel}</a>
      {generoLabel && <span class="genero">{generoLabel}</span>}
    </p>
    <h1>{nota.data.titulo}</h1>
    <p class="bajada">{nota.data.bajada}</p>
    <p class="meta">Por <strong>{nota.data.autor}</strong> · {fechaFmt}</p>
    <div class="cuerpo">
      <Content />
    </div>
    {nota.data.tags && nota.data.tags.length > 0 && (
      <p class="meta" style="margin-top:2rem;">
        Etiquetas: {nota.data.tags.map((t) => <span style="display:inline-block;background:var(--linea);padding:0.15rem 0.5rem;margin-right:0.3rem;border-radius:3px;font-size:0.75rem;">{t}</span>)}
      </p>
    )}
  </article>
</BaseLayout>
