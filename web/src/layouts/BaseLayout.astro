---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  titulo?: string;
  descripcion?: string;
}
const {
  titulo = "Tierra Colorada — Diario digital de Corrientes",
  descripcion = "Política, economía y sociedad de Corrientes con mirada local. Tierra Colorada — diario digital.",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="es-AR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="Tierra Colorada" href="/rss.xml" />
    <link rel="canonical" href={canonical} />
    <title>{titulo}</title>
    <meta name="description" content={descripcion} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={titulo} />
    <meta property="og:description" content={descripcion} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="/logo-isotipo.svg" />
    <meta name="twitter:card" content="summary" />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
